# Secrets — never commit
.env

# Virtual environment
.venv/

# Generated output artifacts (machine-local)
exports/
audit/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# macOS metadata
.DS_Store

# Real / customer data — never commit
# (only *.synthetic.* files are tracked)
data/kb/approved_answers.json
data/questionnaires/*.json
!data/questionnaires/*.synthetic.json
data/kb/docs/*.json
!data/kb/docs/*.synthetic.json

# IDE artifacts
.idea/
.vscode/
*.swp
*.swo

# Pytest cache
.pytest_cache/

# samples/ is a TRACKED directory — do NOT gitignore it.
# It holds ONE redacted demo export + audit for reviewers (see CLAUDE.md §2).
# The live exports/ and audit/ directories above stay gitignored.

# Live-run evidence artifacts (machine-local, regenerated by scripts/run_live_*.py) — never commit.
# Scoped to redteam/ on purpose: a blanket *.jsonl would wrongly catch the mandated
# samples/*.sample.jsonl demo artifact. Curated analysis (REDTEAM_FINDINGS / QA_AUDIT_50 /
# SWEEP_PR3_PR4 .md) is human-written and stays tracked.
redteam/live_review_*.jsonl
redteam/LIVE_REVIEW_*.md
redteam/LIVE_RUN_FINDINGS*.md

# Internal process / scratch / cross-project reference — keep local, NOT for the submitted repo.
# (Reference/ is a different prior project; HANDOFF/crazy_test_prompt are scratch; case_bulk20 is an
# orphan questionnaire referenced nowhere. Untracked via `git rm --cached`; these keep them out.)
Reference/
HANDOFF.md
crazy_test_prompt.md
data/questionnaires/case_bulk20.synthetic.json
